# Example environment for Bun + Hono + Redis + DevCycle

# ── App ───────────────────────────────────────
PORT=3000

# ── Redis ─────────────────────────────────────
# Local run without Docker:
REDIS_URL=redis://localhost:6379
# Docker Compose:
# REDIS_URL=redis://redis:6379

# ── DevCycle ──────────────────────────────────
# Required. Use your DevCycle Server SDK Key.
DEVCYCLE_SERVER_SDK_KEY=server-...

# App config is read from DevCycle variables, not env:
# - admin-api-key          string
# - turnstile-enabled      boolean
# - turnstile-site-key     string
# - turnstile-secret-key   string
